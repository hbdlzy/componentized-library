{
  "name": "company-ui-library",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hbdlzy/componentized-library.git"
  },
  "scripts": {
    "install:all": "pnpm install",
    "build": "pnpm packages:build && pnpm docs:build",
    "packages:build": "pnpm --filter @hbdlzy/tokens build && pnpm --filter @hbdlzy/ui-core build && pnpm --filter @hbdlzy/ui-energy build",
    "tokens:build": "pnpm --filter @hbdlzy/tokens build",
    "ui-core:build": "pnpm --filter @hbdlzy/ui-core build",
    "ui-energy:build": "pnpm --filter @hbdlzy/ui-energy build",
    "docs:dev": "pnpm --filter @hbdlzy/ui-docs dev",
    "docs:build": "pnpm --filter @hbdlzy/ui-docs build",
    "publish:npm:tokens": "pnpm --filter @hbdlzy/tokens publish --no-git-checks",
    "publish:npm:ui-core": "pnpm --filter @hbdlzy/ui-core publish --no-git-checks",
    "publish:npm:ui-energy": "pnpm --filter @hbdlzy/ui-energy publish --no-git-checks",
    "publish:npm:all": "pnpm packages:build && pnpm run publish:npm:tokens && pnpm run publish:npm:ui-core && pnpm run publish:npm:ui-energy",
    "publish:github:tokens": "pnpm --filter @hbdlzy/tokens publish --no-git-checks",
    "publish:github:ui-core": "pnpm --filter @hbdlzy/ui-core publish --no-git-checks",
    "publish:github:ui-energy": "pnpm --filter @hbdlzy/ui-energy publish --no-git-checks",
    "publish:github:all": "pnpm packages:build && pnpm run publish:github:tokens && pnpm run publish:github:ui-core && pnpm run publish:github:ui-energy"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^2.3.4",
    "element-plus": "^2.13.7",
    "typescript": "^4.9.5",
    "vite": "^2.9.18",
    "vue": "^3.5.14"
  }
}
