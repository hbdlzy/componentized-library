{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@hbdlzy/tokens": ["packages/tokens/src/index.ts"],
      "@hbdlzy/tokens/*": ["packages/tokens/src/*"],
      "@hbdlzy/ui-core": ["packages/ui-core/src/index.ts"],
      "@hbdlzy/ui-core/*": ["packages/ui-core/src/*"],
      "@hbdlzy/ui-energy": ["packages/ui-energy/src/index.ts"],
      "@hbdlzy/ui-energy/*": ["packages/ui-energy/src/*"],
      "@hbdlzy/ui": ["packages/ui/src/index.ts"],
      "@hbdlzy/ui/*": ["packages/ui/src/*"]
    },
    "lib": ["ES2020", "DOM"],
    "jsx": "preserve",
    "types": ["vite/client", "node"],
    "esModuleInterop": true
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.vue",
    "apps/**/*.ts",
    "apps/**/*.vue"
  ]
}
