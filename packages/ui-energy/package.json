{
  "name": "@hbdlzy/ui-energy",
  "version": "0.1.1",
  "description": "Company energy domain component package.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hbdlzy/componentized-library.git",
    "directory": "packages/ui-energy"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./components.manifest.json": "./components.manifest.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "components.manifest.json"
  ],
  "peerDependencies": {
    "vue": "^3.5.14"
  },
  "scripts": {
    "build": "vite build && pnpm run build:types",
    "build:types": "vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
