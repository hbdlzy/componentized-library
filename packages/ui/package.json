{
  "name": "@hbdlzy/ui",
  "version": "0.1.3",
  "description": "Company unified UI entry package.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hbdlzy/componentized-library.git",
    "directory": "packages/ui"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./package.manifest.json": "./package.manifest.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "AI-USAGE.md",
    "package.manifest.json"
  ],
  "dependencies": {
    "@hbdlzy/tokens": "workspace:*",
    "@hbdlzy/ui-core": "workspace:*",
    "@hbdlzy/ui-energy": "workspace:*"
  },
  "peerDependencies": {
    "element-plus": "^2.13.7",
    "vue": "^3.5.14"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && pnpm run build:types",
    "build:types": "vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
