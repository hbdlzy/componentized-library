{
  "name": "@hbdlzy/ui-core",
  "version": "0.1.2",
  "description": "Company shared Vue UI core package.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hbdlzy/componentized-library.git",
    "directory": "packages/ui-core"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    },
    "./components.manifest.json": "./components.manifest.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "components.manifest.json"
  ],
  "peerDependencies": {
    "element-plus": "^2.13.7",
    "vue": "^3.5.14"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "exceljs": "^4.4.0",
    "file-saver": "2.0.5"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
