      "importName": "BaseTable",
      "docs": "packages/ui-core/src/components/BaseTable/README.md",
      "description": "统一封装分页、远程请求、排序参数映射、结果适配和常见列渲染能力的基础表格组件。",
      "props": [
        { "name": "columns", "type": "BaseTableColumn[]", "required": true },
        { "name": "data", "type": "Record<string, any>[]", "required": false },
        { "name": "request", "type": "BaseTableRequestHandler", "required": false },
        { "name": "requestParams", "type": "Record<string, unknown>", "required": false },
        {
          "name": "resultAdapter",
          "type": "(result: unknown, params: BaseTableRequestParams) => { rows?: Record<string, any>[]; total?: number }",
          "required": false
