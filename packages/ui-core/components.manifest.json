        { "name": "defaultSort", "type": "BaseTableSortState", "required": false },
        { "name": "sortFieldKey", "type": "string", "default": "sortField" },
        { "name": "sortOrderKey", "type": "string", "default": "sortOrder" },
        {
          "name": "sortMapper",
          "type": "(payload: BaseTableSortPayload) => Record<string, unknown> | void",
          "required": false
        },
        {
