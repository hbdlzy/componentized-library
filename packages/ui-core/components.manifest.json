{
  "package": "@hbdlzy/ui-core",
  "version": 1,
  "updatedAt": "2026-04-21",
  "components": [
    {
      "name": "BaseTable",
      "category": "ui-core",
      "entry": "@hbdlzy/ui-core",
      "importName": "BaseTable",
      "docs": "packages/ui-core/src/components/BaseTable/README.md",
      "description": "统一封装分页、远程请求、勾选列、索引列、操作列和常见表格列渲染能力的基础表格组件。",
      "props": [
        {
          "name": "columns",
          "type": "BaseTableColumn[]",
          "required": true
        },
        {
          "name": "data",
          "type": "Record<string, any>[]",
          "required": false
        },
        {
          "name": "request",
          "type": "BaseTableRequestHandler",
          "required": false
        },
        {
          "name": "requestParams",
          "type": "Record<string, unknown>",
          "required": false
        },
        {
          "name": "resultAdapter",
          "type": "(result: unknown, params: BaseTableRequestParams) => { rows?: Record<string, any>[]; total?: number }",
          "required": false
        },
        {
          "name": "defaultSort",
          "type": "BaseTableSortState",
          "required": false
        },
        {
          "name": "sortFieldKey",
          "type": "string",
          "default": "sortField"
        },
        {
          "name": "sortOrderKey",
          "type": "string",
          "default": "sortOrder"
        },
        {
          "name": "sortMapper",
          "type": "(payload: BaseTableSortPayload) => Record<string, unknown> | void",
          "required": false
        },
        {
          "name": "hasSelection",
          "type": "boolean",
          "default": false
        },
        {
          "name": "hasIndex",
          "type": "boolean",
          "default": false
        },
        {
          "name": "showPagination",
          "type": "boolean",
          "default": true
        }
      ],
      "emits": ["row-action", "selection-change", "sort-change", "page-change", "size-change", "loaded"]
    },
    {
      "name": "BaseCard",
      "category": "ui-core",
      "entry": "@hbdlzy/ui-core",
      "importName": "BaseCard",
      "docs": "packages/ui-core/src/components/BaseCard/README.md",
      "description": "统一封装卡片标题区、右侧信息区、导出触发区和常用卡片视觉样式的基础容器组件。",
      "props": [
        {
          "name": "title",
          "type": "string",
          "default": ""
        },
        {
          "name": "metaText",
          "type": "string",
          "default": ""
        },
        {
          "name": "showHeader",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showTitleMarker",
          "type": "boolean",
          "default": true
        },
        {
          "name": "showExport",
          "type": "boolean",
          "default": false
        },
        {
          "name": "exportPayload",
          "type": "unknown",
          "required": false
        },
        {
          "name": "padding",
          "type": "string | number",
          "default": 20
        },
        {
          "name": "borderColor",
          "type": "string",
          "default": "var(--border-color)"
        },
        {
          "name": "backgroundColor",
          "type": "string",
          "default": "var(--border-bg-color)"
        },
        {
          "name": "markerColor",
          "type": "string",
          "default": "var(--el-color-primary)"
        }
      ],
      "emits": ["export"]
    },
    {
      "name": "BaseEChart",
      "category": "ui-core",
      "entry": "@hbdlzy/ui-core",
      "importName": "BaseEChart",
      "docs": "packages/ui-core/src/components/BaseEChart/README.md",
      "description": "统一封装 ECharts 的初始化、setOption、自动 resize、实例销毁和常用实例方法暴露。",
      "props": [
        {
          "name": "option",
          "type": "EChartOption",
          "required": false
        },
        {
          "name": "theme",
          "type": "string | object",
          "required": false
        },
        {
          "name": "initOptions",
          "type": "EChartInitOptions",
          "required": false
        },
        {
          "name": "setOptionOptions",
          "type": "boolean | EChartSetOptionOptions",
          "required": false
        },
        {
          "name": "loading",
          "type": "boolean",
          "default": false
        },
        {
          "name": "autoResize",
          "type": "boolean",
          "default": true
        },
        {
          "name": "useDefaultColors",
          "type": "boolean",
          "default": true
        }
      ],
      "emits": ["ready"]
    },
    {
      "name": "BaseExportButton",
      "category": "ui-core",
      "entry": "@hbdlzy/ui-core",
      "importName": "BaseExportButton",
      "docs": "packages/ui-core/src/components/BaseExportButton/README.md",
      "description": "统一处理前端 Excel 导出和后端 blob 下载的基础导出按钮。",
      "props": [
        {
          "name": "label",
          "type": "string",
          "default": "导出"
        },
        {
          "name": "fileName",
          "type": "string",
          "default": ""
        },
        {
          "name": "excelOptions",
          "type": "ExcelExportOptions",
          "required": false
        },
        {
          "name": "requestHandler",
          "type": "() => Promise<ExportResponseLike>",
          "required": false
        },
        {
          "name": "beforeExport",
          "type": "() => boolean | Promise<boolean>",
          "required": false
        }
      ],
      "emits": ["start", "success", "error"]
    }
  ],
  "utilities": [
    {
      "name": "echarts",
      "entry": "@hbdlzy/ui-core",
      "description": "统一导出的 echarts 对象，可直接调用 graphic、format 等内置能力。"
    },
    {
      "name": "exportExcel",
      "entry": "@hbdlzy/ui-core",
      "description": "支持多级表头和自动列宽的纯前端 Excel 导出工具。"
    }
  ]
}
